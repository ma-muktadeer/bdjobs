{
    "editor.minimap.enabled": false,
    "git.autofetch": true,
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "terminal.integrated.fontLigatures.enabled": true,
    "editor.fontFamily": "'JetBrainsMono Nerd Font','JetBrainsMono',Consolas, 'Courier New', monospace",
    "editor.inlineSuggest.fontFamily": "'JetBrainsMono Nerd Font','JetBrainsMono',default",
    "debug.console.fontFamily": "'JetBrainsMono Nerd Font','JetBrainsMono',default",
    "scm.inputFontFamily": "'JetBrainsMono Nerd Font','JetBrainsMono',default",
    "notebook.markup.fontFamily": "'JetBrainsMono Nerd Font','JetBrainsMono'",
    "markdown.preview.fontFamily": "'JetBrainsMono Nerd Font','JetBrainsMono',-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
    "typescript.referencesCodeLens.enabled": true,
    "javascript.referencesCodeLens.enabled": true,
    "editor.codeLens": true,
    "editor.stickyScroll.enabled": true,
    "javascript.suggest.autoImports": true,
    "typescript.suggest.autoImports": true,
    "editor.suggestSelection": "first",
    "editor.acceptSuggestionOnEnter": "on",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.git": true,
        "node_modules": true,
        ".vscode": false
    },
    "editor.multiCursorModifier": "ctrlCmd",
    "typescript.tsserver.watchOptions": "vscode"
}